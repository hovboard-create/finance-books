# Copy to .env.local and fill in. .env.local is gitignored.
#
# Amazon Product Advertising API (PA-API 5.0) credentials.
# Get yours at: https://affiliate-program.amazon.com/assoc_credentials/home
#
# Used by: scripts/refresh-amazon.ts
# Refresh schedule: daily (Amazon TOS requires displayed prices < 24h old)

AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=hovboard-20
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1

# Optional override of the default Amazon Associates tag baked into the build
# (defaults to AMAZON_PARTNER_TAG above when not set).
# NEXT_PUBLIC_AMAZON_TAG=hovboard-20

# YouTube Data API v3 key — used by scripts/fetch-youtube.ts to find author
# talks for each book. Free tier: 10K units/day; each book search costs 100.
# Setup: enable YouTube Data API v3 at https://console.cloud.google.com,
# create an API key, paste below.
YOUTUBE_API_KEY=
